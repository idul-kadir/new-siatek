    </div>

    <!-- ===================== MODAL: Tanda Tangan Digital ===================== -->
    <div class="modal fade" id="signModal" tabindex="-1" aria-labelledby="signModalLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title" id="signModalLabel"><i class="bi bi-pen-fill me-2"></i>Tanda Tangan Digital</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center mb-3">
                        <i class="bi bi-shield-check text-primary" style="font-size:2.5rem;"></i>
                    </div>
                    <p class="text-center mb-3" style="font-size:.88rem;">Anda akan menandatangani surat berikut:</p>
                    <div class="signature-preview p-3 rounded-3 bg-light mb-3">
                        <p class="mb-1" style="font-size:.82rem;"><strong>Mahasiswa:</strong> Ahmad Fauzi</p>
                        <p class="mb-1" style="font-size:.82rem;"><strong>No. Surat:</strong> SK-2026/0847</p>
                        <p class="mb-0" style="font-size:.82rem;"><strong>Jenis:</strong> Surat Keterangan Lulus</p>
                    </div>
                    <div class="form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="confirmSignCheck">
                        <label class="form-check-label" for="confirmSignCheck" style="font-size:.82rem;">Saya yakin dokumen ini sudah benar untuk ditandatangani.</label>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-sm btn-secondary" data-bs-dismiss="modal">Batal</button>
                    <button type="button" class="btn btn-sm btn-primary" id="btnConfirmSign"><i class="bi bi-pen-fill me-1"></i> Konfirmasi &amp; Tanda Tangan</button>
                </div>
            </div>
        </div>
    </div>

